{
  "compilerOptions": {
    "target": "ESNext",
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "lib": [
      "ES2024",
      "DOM",
      "DOM.AsyncIterable",
      "DOM.Iterable",
      "ESNext.Array"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "#macros": [
        "./macros/index.ts"
      ],
    },
    "allowJs": true,
    "strict": true,
    "outDir": "temp/dist",
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  }
}